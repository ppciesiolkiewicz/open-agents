{
  "name": "open-agents-agent-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:interactive": "INTERACTIVE_TESTS=1 vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "zerog-bootstrap": "tsx src/ai/zerog-broker/bootstrap-cli.ts"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "openai": "^4.104.0",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
