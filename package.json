{
  "name": "open-agents-agent-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "NODE_OPTIONS=--conditions=require tsx src/index.ts",
    "dev": "NODE_OPTIONS=--conditions=require tsx watch src/index.ts",
    "test": "NODE_OPTIONS=--conditions=require vitest run",
    "test:watch": "NODE_OPTIONS=--conditions=require vitest",
    "swap:buy-uni": "NODE_OPTIONS=--conditions=require tsx scripts/swap-buy-uni.ts",
    "swap:sell-uni": "NODE_OPTIONS=--conditions=require tsx scripts/swap-sell-uni.ts",
    "llm:probe": "NODE_OPTIONS=--conditions=require tsx scripts/zerog-llm-probe.ts",
    "seed-agent": "NODE_OPTIONS=--conditions=require tsx scripts/seed-agent.ts",
    "reset-db": "NODE_OPTIONS=--conditions=require tsx scripts/reset-db.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "zerog-bootstrap": "NODE_OPTIONS=--conditions=require tsx src/ai/zerog-broker/bootstrap-cli.ts"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.5",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "openai": "^4.104.0",
    "swagger-ui-express": "^5.0.1",
    "viem": "^2.21.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
