{
  "name": "open-agents-agent-loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "NODE_OPTIONS=--conditions=require tsx src/index.ts",
    "start:looper": "MODE=looper NODE_OPTIONS=--conditions=require tsx src/index.ts",
    "start:server": "MODE=server NODE_OPTIONS=--conditions=require tsx src/index.ts",
    "dev": "NODE_OPTIONS=--conditions=require tsx watch src/index.ts",
    "dev:looper": "MODE=looper NODE_OPTIONS=--conditions=require tsx watch src/index.ts",
    "dev:server": "MODE=server NODE_OPTIONS=--conditions=require tsx watch src/index.ts",
    "test": "NODE_OPTIONS=--conditions=require vitest run",
    "test:watch": "NODE_OPTIONS=--conditions=require vitest",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:nuke": "docker compose down -v",
    "db:logs": "docker compose logs -f postgres",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "db:seed": "NODE_OPTIONS=--conditions=require tsx prisma/seed.ts",
    "llm:probe": "NODE_OPTIONS=--conditions=require tsx scripts/tests/zerog-llm-probe.ts",
    "llm:probe:streaming": "NODE_OPTIONS=--conditions=require tsx scripts/tests/zerog-llm-probe-streaming.ts",
    "swap:buy-uni": "NODE_OPTIONS=--conditions=require tsx scripts/tests/swap-buy-uni.ts",
    "swap:sell-uni": "NODE_OPTIONS=--conditions=require tsx scripts/tests/swap-sell-uni.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "zerog-bootstrap": "NODE_OPTIONS=--conditions=require tsx src/ai/zerog-broker/bootstrap-cli.ts"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.5",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@prisma/client": "^6.19.3",
    "@privy-io/server-auth": "^1.32.5",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "openai": "^4.104.0",
    "swagger-ui-express": "^5.0.1",
    "viem": "^2.21.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^20.14.0",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "^6.19.3",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "prisma": {
    "seed": "NODE_OPTIONS=--conditions=require tsx prisma/seed.ts"
  }
}
